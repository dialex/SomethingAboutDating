#!/bin/sh
# Bump version in manifest.json and service-worker.js on every commit.
# Defaults to patch. Override with BUMP=minor or BUMP=major when committing
# a milestone, e.g. `BUMP=minor git commit -m "..."`.

VERSION=$(node -p "require('./manifest.json').version")
BUMP="${BUMP:-patch}"

NEW_VERSION=$(node -p "
  const parts = '$VERSION'.split('.').map(Number);
  while (parts.length < 3) parts.push(0);
  const bump = '$BUMP';
  if (bump === 'major') { parts[0] += 1; parts[1] = 0; parts[2] = 0; }
  else if (bump === 'minor') { parts[1] += 1; parts[2] = 0; }
  else { parts[2] += 1; }
  parts.join('.');
")

node -e "
  const fs = require('fs');
  const m = JSON.parse(fs.readFileSync('manifest.json', 'utf8'));
  m.version = '$NEW_VERSION';
  fs.writeFileSync('manifest.json', JSON.stringify(m, null, 2) + '\n');
"

node -e "
  const fs = require('fs');
  let sw = fs.readFileSync('service-worker.js', 'utf8');
  sw = sw.replace(/const CACHE_NAME = \"something-dating-v[^\"]+\"/, 'const CACHE_NAME = \"something-dating-v$NEW_VERSION\"');
  fs.writeFileSync('service-worker.js', sw);
"

git add manifest.json service-worker.js
echo "Version bumped to v$NEW_VERSION"
